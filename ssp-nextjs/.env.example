# Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Backend API URL (our existing FastAPI backend on Render)
NEXT_PUBLIC_API_URL=https://svadista-backend.onrender.com/api

# Google Analytics 4 Measurement ID (optional but recommended)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Base URL — used by the SEO validator script
BASE_URL=http://localhost:3000
